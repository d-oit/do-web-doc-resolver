#!/bin/bash
# Pre-commit hook for do-web-doc-resolver
# Integrates Gitleaks secret scanning with quality gate

set -e

echo "Running pre-commit checks..."

# Run Gitleaks secret scan
if command -v gitleaks &> /dev/null; then
    echo "Scanning for secrets with Gitleaks..."
    gitleaks protect --verbose --redact --staged --config=.gitleaks.toml || {
        echo "❌ Gitleaks detected potential secrets. Please review and fix."
        exit 1
    }
else
    echo "⚠️  Gitleaks not installed. Install with: brew install gitleaks (macOS) or go install github.com/gitleaks/gitleaks@latest"
fi

# Run quality gate
if [ -f "./scripts/quality_gate.sh" ]; then
    echo "Running quality gate..."
    ./scripts/quality_gate.sh
fi

echo "✅ Pre-commit checks passed!"
