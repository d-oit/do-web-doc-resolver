#!/bin/bash
# Pre-commit hook for do-web-doc-resolver
# Runs quality gate before commit
# Note: Gitleaks runs via GitHub Action (.github/workflows/gitleaks.yml)

set -e

echo "Running pre-commit checks..."

# Run quality gate
if [ -f "./scripts/quality_gate.sh" ]; then
    echo "Running quality gate..."
    ./scripts/quality_gate.sh
fi

echo "✅ Pre-commit checks passed!"
echo "ℹ️  Secret scanning (Gitleaks) runs via GitHub Actions on push/PR."
