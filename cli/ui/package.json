{
  "name": "do-web-doc-resolver-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Design system and component library for do-web-doc-resolver",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "chromatic": "npx chromatic --project-token=${CHROMATIC_PROJECT_TOKEN}",
    "lint": "stylelint 'components/**/*.css' 'tokens/**/*.css' 'layouts/**/*.css'",
    "lint:fix": "stylelint 'components/**/*.css' 'tokens/**/*.css' 'layouts/**/*.css' --fix",
    "test": "node scripts/validate-css.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "storybook": "^8.6.0",
    "@storybook/html-vite": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "@playwright/test": "^1.50.0"
  }
}
