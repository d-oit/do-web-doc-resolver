# Environment variables for web-doc-resolver UI
# Copy this file to .env.local and fill in values

# App URL (used for absolute links and OG images)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: API endpoint for the resolver backend
NEXT_PUBLIC_RESOLVER_URL=http://localhost:8000

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=